<script>
// 記錄重播狀態
const repeatStatus = {};
const container = document.getElementById("word-container");

// 初始化：先抓取 list.json 索引檔，再依序載入所有 .txt
async function init() {
  container.innerHTML = "正在讀取索引檔...";

  try {
    // 讀取 list.json 獲取檔案清單
    const listResponse = await fetch("txt/list.json");
    if (!listResponse.ok) throw new Error("無法讀取 list.json 索引檔");
    
    const fileList = await listResponse.json();
    
    // 清空載入中提示
    container.innerHTML = "";
    
    // 循環載入清單內的檔案
    for (const fileName of fileList) {
      await loadWordsFromFile(fileName);
    }
    
    if (fileList.length === 0) {
      container.innerHTML = "索引檔內沒有任何檔案。";
    }
  } catch (err) {
    console.error(err);
    container.innerHTML = `<p style="color:red">初始化失敗：${err.message}</p>`;
  }
}

// 載入單一檔案並建立折疊區塊
async function loadWordsFromFile(fileName) {
  try {
    const response = await fetch(`txt/${fileName}`);
    if (!response.ok) throw new Error(`找不到檔案: ${fileName}`);
    
    const sectionTitleText = fileName.replace(/\.(txt|json)$/, "");
    const section = document.createElement("section");
    section.className = "section";

  const title = document.createElement("div");
  title.className = "section-title";
  // 增加一個容器讓標題和按鈕分開
  title.style.display = "flex";
  title.style.justifyContent = "space-between";
  title.style.alignItems = "center";

  // 左側標題內容
  const titleText = document.createElement("span");
  titleText.innerHTML = `<span class="arrow">▶</span> ${sectionTitleText}`;
  title.appendChild(titleText);

  // 右側循環播放按鈕
  const loopBtn = document.createElement("button");
  loopBtn.className = "control-button";
  loopBtn.style.fontSize = "12px";
  loopBtn.style.padding = "2px 8px";
  loopBtn.style.margin = "0";
  loopBtn.style.borderColor = "#00ff99";
  loopBtn.style.backgroundColor = "transparent";
  loopBtn.style.color = "#00ff99";
  loopBtn.innerText = "🔁 循環播放區塊";

  // 點擊按鈕時執行循環邏輯
  loopBtn.addEventListener("click", (e) => {
    e.stopPropagation(); // 阻止折疊區塊收合
    toggleSectionLoop(sectionTitleText, loopBtn);
  });

  title.appendChild(loopBtn);

    const row = document.createElement("div");
    row.className = "content-row collapsed";

    title.addEventListener("click", () => {
      row.classList.toggle("collapsed");
      title.querySelector(".arrow").classList.toggle("rotate");
    });

    let wordList = [];

    // --- 判斷檔案格式 ---
    if (fileName.endsWith(".json")) {
      wordList = await response.json();
    } else {
      // 兼容舊有的 txt 格式
      const text = await response.text();
      wordList = text.split("\n").map(line => {
        const idx = line.indexOf("|");
        if (idx !== -1) {
          return {
            word: line.substring(0, idx).trim(),
            translation: line.substring(idx + 1).trim()
          };
        }
        return null;
      }).filter(item => item !== null);
    }

   // --- 渲染單字卡 (已修正加入筆記功能) ---
    wordList.forEach(item => {
      const word = item.word;
      const translation = item.translation;
      const kk = item.kk || ""; 
      const note = (item.note || "").trim(); // 讀取 note 並去除空白
      const safeWord = word.replace(/'/g, "\\'");

      const card = document.createElement("div");
      card.className = "term-card";
      card.dataset.word = word;

      // 關鍵：判斷 note 是否存在
      const hasNote = note.length > 0;
      const noteButtonHtml = hasNote ? `<button class="note-btn" onclick="toggleNote(this)" title="查看筆記">📝</button>` : "";
      const noteContentHtml = hasNote ? `<div class="note-content">${note}</div>` : "";

      card.innerHTML = `
          ${noteButtonHtml}
          <button class="eye-btn" onclick="toggleSingleWord(this)">👁️</button>
          <div class="main-text">${word}</div> 
          <div class="sub-text" style="color: #00ff99; font-family: Arial; margin-bottom: 4px;">${kk}</div>
          <div class="button-group">
              <button class="speak-button" onclick="speakWord('${safeWord}','en-GB')">🇬🇧 英式</button>
              <button class="speak-button" onclick="speakWord('${safeWord}','en-US')">🇺🇸 美式</button>
              <button class="speak-button" onclick="repeatSpeak('${safeWord}','en-GB')">🔁 英式重播</button>
              <button class="speak-button" onclick="repeatSpeak('${safeWord}','en-US')">🔁 美式重播</button>
          </div>
          <div class="sub-text">${translation}</div>
          ${noteContentHtml}
      `;
      row.appendChild(card);
    });

    section.appendChild(title);
    section.appendChild(row);
    container.appendChild(section);

    // 同步更新測驗池 (Quiz Pool)
   quizPool[sectionTitleText] = wordList.map(item => ({
      en: item.word,
      cn: item.translation
    }));
updateQuizRangeUI(sectionTitleText);
  } catch (err) {
    console.warn(`跳過檔案 ${fileName}: ${err.message}`);
  }
}

