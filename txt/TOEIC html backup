init();

// --- 測驗功能專用的全域變數 ---
let quizPool = {}; 
let currentQuizList = [];
let quizIndex = 0; 
let correctCount = 0;
let wrongCount = 0;
let isAnswering = false;
let currentQuizType = "cn-en";

// 洗牌演算法
function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
    }
}

// 更新下拉選單 (此函式由 loadWordsFromFile 在載入成功後呼叫)
function updateQuizRangeUI(catName) {
    const sel = document.getElementById("quizRange");
    // 檢查是否已經存在該選項，避免重複添加
    if (!Array.from(sel.options).some(opt => opt.value === catName)) {
        const opt = document.createElement("option");
        opt.value = catName;
        opt.textContent = catName;
        sel.appendChild(opt);
    }
}

// 修改 loadWordsFromFile 內部邏輯以支援 UI 更新
// (請確保你先前的 loadWordsFromFile 函式末端有呼叫 updateQuizRangeUI)
// 為了保險起見，這裡提供一個「自動修復版」的測驗範圍初始化
function openQuiz() {
    const range = document.getElementById("quizRange").value;
    currentQuizType = document.getElementById("quizMode").value;
    currentQuizList = [];
    
    if(range === "all") {
        Object.values(quizPool).forEach(list => currentQuizList.push(...list));
    } else {
        currentQuizList = quizPool[range] ? [...quizPool[range]] : [];
    }

    if(currentQuizList.length < 4) {
        alert("該範圍單字量不足 4 個，無法開始測驗！");
        return;
    }

    shuffleArray(currentQuizList);
    quizIndex = 0;
    correctCount = 0;
    wrongCount = 0;
    document.getElementById("correctList").innerHTML = "";
    document.getElementById("wrongList").innerHTML = "";
    document.getElementById("quizCorrect").textContent = "0";
    document.getElementById("quizWrong").textContent = "0";
    document.getElementById("quizModal").style.display = "flex";
    
    nextQuestion();
}

// ... 剩下的 closeQuiz, nextQuestion, handleAnswer, updateSideList, finishQuiz 邏輯保持不變 ...

function closeQuiz() {
    if(quizIndex < currentQuizList.length && quizIndex > 0) {
        if(!confirm("測驗尚未結束，確定要提前離開嗎？")) return;
    }
    document.getElementById("quizModal").style.display = "none";
    speechSynthesis.cancel();
}
function nextQuestion() {
    if (quizIndex >= currentQuizList.length) {
        finishQuiz();
        return;
    }

    isAnswering = false;
    document.getElementById("quizFeedback").textContent = "";
    document.getElementById("quizProgress").textContent = `進度: ${quizIndex + 1} / ${currentQuizList.length}`;
    
    const optionsBox = document.getElementById("quizOptions");
    optionsBox.innerHTML = "";

    const target = currentQuizList[quizIndex];

    // --- 根據題型決定題目顯示 ---
    // 中選英：題目顯示中文；英選中：題目顯示英文
    document.getElementById("quizQuestionCN").textContent = 
        (currentQuizType === "cn-en") ? target.cn : target.en;

    let allFlattened = [];
    Object.values(quizPool).forEach(l => allFlattened.push(...l));
    
    let distractors = [];
    while(distractors.length < 3) {
        let rand = allFlattened[Math.floor(Math.random() * allFlattened.length)];
        // 確保干擾項不重複且不是正確答案
        if(rand.en !== target.en && !distractors.find(d => d.en === rand.en)) {
            distractors.push(rand);
        }
    }

    let options = [target, ...distractors].sort(() => Math.random() - 0.5);

    options.forEach(opt => {
        const btn = document.createElement("button");
        btn.className = "option-btn";
        
        // --- 根據題型決定按鈕顯示文字 ---
        // 中選英：按鈕顯示英文；英選中：按鈕顯示中文
        btn.textContent = (currentQuizType === "cn-en") ? opt.en : opt.cn;
        
        btn.onclick = () => handleAnswer(opt, target, btn);
        optionsBox.appendChild(btn);
    });
}

function handleAnswer(selectedObj, targetObj, btnElement) {
    if(isAnswering) return;
    isAnswering = true;

    const isCorrect = selectedObj.en === targetObj.en;

    if(isCorrect) {
        correctCount++;
        document.getElementById("quizCorrect").textContent = correctCount;
        btnElement.classList.add("option-correct");
        document.getElementById("quizFeedback").style.color = "#00ff99";
        document.getElementById("quizFeedback").textContent = "Correct! ✓";
        updateSideList("correctList", targetObj, "correct");
    } else {
        wrongCount++;
        document.getElementById("quizWrong").textContent = wrongCount;
        btnElement.classList.add("option-wrong");
        document.getElementById("quizFeedback").style.color = "#ff5555";
        
        const correctText = (currentQuizType === "cn-en") ? targetObj.en : targetObj.cn;
        document.getElementById("quizFeedback").textContent = `Wrong! 正確答案是: ${correctText}`;
        
        updateSideList("wrongList", targetObj, "wrong");
        
        Array.from(document.querySelectorAll(".option-btn")).forEach(b => {
            if(b.textContent === correctText) b.classList.add("option-correct");
        });
    }

    // --- 關鍵修正：使用高品質發音，並在播放結束後才跳下一題 ---
    // 這裡我們帶入一個 callback 函式
    speakWord(targetObj.en, 'en-US', () => {
        quizIndex++;
        setTimeout(nextQuestion, 800);
    });
}

// 更新左右側清單
function updateSideList(listId, wordObj, type) {
    const list = document.getElementById(listId);
    const item = document.createElement("div");
    item.className = `sidebar-item ${type}`;
    
    // 處理單引號避免 JS 報錯
    const safeEn = wordObj.en.replace(/'/g, "\\'");
    
    item.innerHTML = `
        <div>
            <b>${wordObj.en}</b><br>
            <small>${wordObj.cn}</small>
        </div>
        <button class="speak-button" onclick="speakWord('${safeEn}', 'en-US')">🔊</button>
    `;
    // 讓最新的顯示在最上面
    list.insertBefore(item, list.firstChild);
}

function finishQuiz() {
    document.getElementById("quizQuestionCN").textContent = "🎊 測驗完成！";
    document.getElementById("quizOptions").innerHTML = `
        <div style="color:#fff; font-size: 20px; margin: 20px 0;">
            正確題數：${correctCount} <br>
            錯誤題數：${wrongCount}
        </div>
        <button class="search-button" onclick="document.getElementById('quizModal').style.display='none'">關閉結果</button>
    `;
    document.getElementById("quizFeedback").textContent = "";
}

  // 切換單個單字的顯示/隱藏
function toggleSingleWord(btn) {
    const mainText = btn.nextElementSibling; // 眼睛下一個元素就是 main-text
    mainText.classList.toggle("hidden-word");
    
    // 切換眼睛圖示
    if (mainText.classList.contains("hidden-word")) {
        btn.textContent = "🙈";
    } else {
        btn.textContent = "👁️";
    }
}

// 全域控制：全部顯示或全部隱藏
function toggleAllWords(shouldHide) {
    const allWords = document.querySelectorAll(".main-text");
    const allEyeBtns = document.querySelectorAll(".eye-btn");
    
    allWords.forEach(word => {
        if (shouldHide) {
            word.classList.add("hidden-word");
        } else {
            word.classList.remove("hidden-word");
        }
    });
    
    allEyeBtns.forEach(btn => {
        btn.textContent = shouldHide ? "🙈" : "👁️";
    });
}


  // 切換筆記顯示/隱藏的函數
function toggleNote(btn) {
    // 找到同一個字卡內的 note-content
    const card = btn.closest('.term-card');
    const noteContent = card.querySelector(".note-content");
    if (noteContent) {
        noteContent.classList.toggle("show");
        // 點擊後稍微改變按鈕透明度代表已開啟
        btn.style.opacity = noteContent.classList.contains("show") ? "0.5" : "1";
    }
}

  // 記錄各區塊的播放狀態
const sectionLoopStatus = {};
function toggleSectionLoop(sectionName, btnElement) {
    // 如果該區塊正在播放，則停止
    if (sectionLoopStatus[sectionName]) {
        sectionLoopStatus[sectionName] = false;
        window.speechSynthesis.cancel();
        btnElement.innerText = "🔁 循環播放區塊";
        btnElement.style.backgroundColor = "transparent";
        btnElement.style.color = "#00ff99";
        return;
    }

    // 停止所有其他正在進行的發音
    window.speechSynthesis.cancel();
    // 將所有其他按鈕重置（可選）
    document.querySelectorAll(".section-title .control-button").forEach(btn => {
        if (btn !== btnElement) {
            btn.innerText = "🔁 循環播放區塊";
            btn.style.backgroundColor = "transparent";
            btn.style.color = "#00ff99";
        }
    });

    // 標記目前區塊為播放中
    // 先把所有狀態清空，確保一次只有一個區塊在循環
    for (let key in sectionLoopStatus) sectionLoopStatus[key] = false;
    sectionLoopStatus[sectionName] = true;

    btnElement.innerText = "⏹ 停止播放";
    btnElement.style.backgroundColor = "#00ff99";
    btnElement.style.color = "#000";

    const words = quizPool[sectionName];
    if (!words || words.length === 0) return;

    let currentIndex = 0;

    function playNext() {
        if (!sectionLoopStatus[sectionName]) return; // 如果狀態被切換為 false，停止遞迴

        const wordObj = words[currentIndex];
        const utterance = new SpeechSynthesisUtterance(wordObj.en);
        utterance.lang = 'en-US';
        utterance.rate = 0.9; // 稍微放慢一點點，聽得比較清楚

        utterance.onend = () => {
            if (sectionLoopStatus[sectionName]) {
                currentIndex = (currentIndex + 1) % words.length; // 循環索引
                setTimeout(playNext, 1000); // 每個單字間隔 1 秒
            }
        };

        utterance.onerror = () => {
            sectionLoopStatus[sectionName] = false;
            btnElement.innerText = "🔁 循環播放區塊";
        };

        window.speechSynthesis.speak(utterance);
    }

    playNext();
}
  
</script>
 

